# Copy this file to .env and fill in real values

# Postgres (used when running backend locally, not via docker-compose)
DATABASE_URL=postgresql+psycopg2://dsa:dsa@localhost:5432/algolog

# Simple shared-secret auth between extension <-> backend (personal tool, not multi-user)
API_KEY=changemetosomethingrandom

# Weekly email digest (Sunday). Use a Gmail App Password, not your real password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
DIGEST_TO_EMAIL=your-email@gmail.com

# Embedding model (runs locally via sentence-transformers, downloads once, free)
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384
