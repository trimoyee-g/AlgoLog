# Copy this file to .env and fill in real values

# Postgres + pgvector (docker-compose overrides the host to `postgres`)
DATABASE_URL=postgresql+psycopg2://dsa:dsa@localhost:5432/algolog

# Supabase project that issues the JWTs. The backend only verifies them, against
# <this-url>/auth/v1/.well-known/jwks.json — so no Supabase key or secret is needed.
# REQUIRED, no default: the backend refuses to boot without it, rather than
# verifying your users' tokens against somebody else's Supabase project.
SUPABASE_PROJECT_URL=https://<your-ref>.supabase.co/

# CORS origin for the dashboard
FRONTEND_ORIGIN=http://localhost:5173

# Public base URL of this backend, advertised by the hosted MCP server (POST /mcp) as
# its resource identifier. Claude checks the token was issued for this exact URL, so
# in a real deployment it must be the address clients actually reach — not localhost.
MCP_PUBLIC_URL=http://localhost:8000

# Weekly email digest (Sunday), sent to each user's own address. Use a Gmail App
# Password, not your real password. Leave SMTP_USER / SMTP_PASSWORD empty to skip
# email entirely.
# Note: Gmail caps ~500 recipients/day — past a few hundred users, point this at a
# real transactional sender (SES / Postmark / Resend) instead.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Embedding model (runs locally via sentence-transformers, downloads once, free)
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384

# Optional: local Ollama model that enriches the weekly digest (personalized
# paragraph, study tips, web-searched problems). Empty = disabled; the digest
# still sends its deterministic content. Pull the model first:
#   docker compose exec ollama ollama pull llama3.1
# OLLAMA_BASE_URL is set to http://ollama:11434 by docker-compose; override only
# if running the backend outside compose (then use http://localhost:11434).
OLLAMA_MODEL=
