{
  "manifest_version": 3,
  "name": "AlgoLog",
  "version": "1.0.0",
  "description": "Self-rate every LeetCode/Codeforces/CodeChef/AtCoder/GFG submission so you actually remember which problems you struggled with.",
  "permissions": ["storage", "activeTab", "tabs"],
  "host_permissions": [
    "http://localhost:8000/*",
    "http://localhost:5173/*"
  ],
  "background": {
    "service_worker": "background.js",
    "scripts": ["config.js", "background.js"]
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "AlgoLog"
  },
  "content_scripts": [
    {
      "matches": ["http://localhost:5173/*"],
      "js": ["content_scripts/bridge.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
