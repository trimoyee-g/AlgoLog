{
  "manifest_version": 3,
  "name": "AlgoLog",
  "version": "1.0.0",
  "description": "Self-rate every LeetCode/Codeforces/CodeChef/AtCoder/GFG submission so you actually remember which problems you struggled with.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "https://leetcode.com/*",
    "https://codeforces.com/*",
    "https://www.codechef.com/*",
    "https://atcoder.jp/*",
    "https://www.geeksforgeeks.org/*",
    "http://localhost:8000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "AlgoLog"
  },
  "content_scripts": [
    {
      "matches": ["https://leetcode.com/problems/*"],
      "js": ["content_scripts/common.js", "content_scripts/leetcode.js"],
      "css": ["content_scripts/overlay.css"]
    },
    {
      "matches": ["https://codeforces.com/*"],
      "js": ["content_scripts/common.js", "content_scripts/codeforces.js"],
      "css": ["content_scripts/overlay.css"]
    },
    {
      "matches": ["https://www.codechef.com/*"],
      "js": ["content_scripts/common.js", "content_scripts/codechef.js"],
      "css": ["content_scripts/overlay.css"]
    },
    {
      "matches": ["https://atcoder.jp/*"],
      "js": ["content_scripts/common.js", "content_scripts/atcoder.js"],
      "css": ["content_scripts/overlay.css"]
    },
    {
      "matches": ["https://www.geeksforgeeks.org/*"],
      "js": ["content_scripts/common.js", "content_scripts/gfg.js"],
      "css": ["content_scripts/overlay.css"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
