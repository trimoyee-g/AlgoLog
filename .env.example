# Copy to .env (next to docker-compose.yml). Compose reads this file to
# interpolate ${...} in docker-compose.yml — it is NOT the backend's env file;
# the backend's app config lives in backend/.env (see backend/.env.example).
#
# There are no defaults in docker-compose.yml, so compose refuses to start until
# these are set. Pick a real password — this Postgres publishes port 5432.

POSTGRES_USER=dsa
POSTGRES_PASSWORD=change-me
POSTGRES_DB=algolog
